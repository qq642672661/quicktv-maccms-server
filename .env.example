NODE_ENV=development
PORT=3000
HOST=0.0.0.0

DATABASE_URL=postgresql://quicktv_user:your_password@localhost:5432/quicktv
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=quicktv
DATABASE_USER=quicktv_user
DATABASE_PASSWORD=your_password
DATABASE_MAX_CONNECTIONS=20
DATABASE_IDLE_TIMEOUT=30000

REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=3600

JWT_SECRET=your_jwt_secret_key_min_32_characters_long
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

RABBITMQ_URL=amqp://quicktv:your_password@localhost:5672
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=quicktv
RABBITMQ_PASSWORD=your_password

MACCMS_API_URL=http://your-maccms-api.com
MACCMS_API_KEY=your_maccms_api_key

CORS_ORIGIN=http://localhost:8080,http://localhost:3001
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

LOG_LEVEL=debug
LOG_FILE_PATH=./logs

ENCRYPTION_KEY=your_encryption_key_32_bytes_hex

UPLOAD_MAX_SIZE=10485760
UPLOAD_PATH=./uploads

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_email_password
SMTP_FROM=noreply@quicktv.com
