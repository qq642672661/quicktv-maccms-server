# 数据库类型配置
# 可选值: postgresql, postgres, pg, sqlite, sqlite3
DB_TYPE=postgresql

# ============================================
# PostgreSQL 配置
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=quicktv
DB_USER=postgres
DB_PASSWORD=postgres

# 或者使用 DATABASE_URL (优先级更高)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/quicktv

# ============================================
# SQLite 配置
# ============================================
# SQLite 数据库文件路径 (当 DB_TYPE=sqlite 时使用)
SQLITE_PATH=./data/quicktv.db
# 或者使用 DB_PATH
# DB_PATH=./data/quicktv.db

# ============================================
# 服务器配置
# ============================================
PORT=3000
NODE_ENV=development

# ============================================
# Redis 配置 (可选)
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================
# JWT 配置
# ============================================
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# ============================================
# 日志配置
# ============================================
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# ============================================
# CORS 配置
# ============================================
CORS_ORIGIN=*

# ============================================
# 缓存配置
# ============================================
CACHE_TTL=3600
CACHE_MAX_SIZE=100
